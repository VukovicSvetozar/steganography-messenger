<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane maxHeight="480.0" maxWidth="700.0" minHeight="480.0" minWidth="700.0" prefHeight="480.0" prefWidth="700.0" style="-fx-background-color: ffff55;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CitanjePoruke">
   <children>
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="700.0" minWidth="700.0" prefWidth="700.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints maxHeight="80.0" minHeight="80.0" prefHeight="80.0" vgrow="SOMETIMES" />
          <RowConstraints maxHeight="400.0" minHeight="400.0" prefHeight="400.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextArea fx:id="taDekriptovanjePoruke" maxHeight="350.0" maxWidth="630.0" minHeight="350.0" minWidth="630.0" prefHeight="350.0" prefWidth="630.0" GridPane.rowIndex="1">
               <GridPane.margin>
                  <Insets bottom="25.0" left="25.0" right="45.0" top="25.0" />
               </GridPane.margin>
            </TextArea>
            <GridPane>
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="500.0" minWidth="500.0" prefWidth="500.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="200.0" minWidth="200.0" prefWidth="200.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints maxHeight="80.0" minHeight="80.0" prefHeight="80.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <HBox prefHeight="80.0" prefWidth="500.0" spacing="20.0">
                     <children>
                        <Label text="Odaberite poruku:">
                           <font>
                              <Font name="System Bold Italic" size="14.0" />
                           </font>
                           <HBox.margin>
                              <Insets top="18.0" />
                           </HBox.margin>
                        </Label>
                        <ComboBox fx:id="cbOdaberiPoruku" onAction="#odaberiPoruku" prefWidth="150.0">
                           <HBox.margin>
                              <Insets top="15.0" />
                           </HBox.margin></ComboBox>
                     </children>
                     <GridPane.margin>
                        <Insets left="60.0" top="30.0" />
                     </GridPane.margin>
                  </HBox>
                  <Button fx:id="btnDekriptuj" minHeight="70.0" minWidth="70.0" mnemonicParsing="false" onAction="#dekriptuj" prefHeight="70.0" prefWidth="70.0" text="Dekriptuj" GridPane.columnIndex="1">
                     <graphic>
                        <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../style/ProcitajPoruku.png" />
                           </image></ImageView>
                     </graphic>
                     <GridPane.margin>
                        <Insets top="15.0" />
                     </GridPane.margin>
                     <padding>
                        <Insets right="10.0" />
                     </padding>
                  </Button>
               </children>
            </GridPane>
         </children>
      </GridPane>
   </children>
</AnchorPane>
